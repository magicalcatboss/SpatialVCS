GEMINI_API_KEY=your_gemini_api_key_here
POSTGRES_DB=spatialvcs
POSTGRES_USER=spatial
POSTGRES_PASSWORD=spatial
DATABASE_URL=postgresql+asyncpg://spatial:spatial@localhost:5432/spatialvcs
COMPOSE_DATABASE_URL=postgresql+asyncpg://spatial:spatial@postgres:5432/spatialvcs
SPATIAL_GEMINI_QUEUE_MAX_SIZE=128
SPATIAL_GEMINI_QUEUE_CONCURRENCY=2
SPATIAL_GEMINI_JOB_TIMEOUT_SEC=10
SPATIAL_ID_MATCH_DISTANCE_M=0.6
SPATIAL_ID_STALE_SEC=3.0
SPATIAL_METRICS_ENABLED=true
SPATIAL_DEFAULT_DEPTH_M=1.5
